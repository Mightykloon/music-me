generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  CREATOR
  ADMIN
}

enum LayoutStyle {
  CLASSIC
  BENTO
  MINIMAL
  MAGAZINE
  MYSPACE
}

enum MusicProviderType {
  SPOTIFY
  APPLE_MUSIC
  SOUNDCLOUD
  YOUTUBE_MUSIC
  LASTFM
  DEEZER
  TIDAL
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
  POLL
  LYRIC_CARD
  PLAYLIST_DROP
  NOW_PLAYING
  REPOST
}

enum Visibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

enum ReactionType {
  FIRE
  HEADPHONES
  ENCORE
  SKIP
  HEART
  HUNDRED
}

enum NotificationType {
  FOLLOW
  REACTION
  COMMENT
  REPOST
  MENTION
  PLAYLIST_DROP
}

// ─── Users ───────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  displayName   String?
  passwordHash  String?
  bio           String?   @db.Text
  pronouns      String?
  location      String?
  website       String?
  emailVerified DateTime?
  isVerified    Boolean   @default(false)
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile          UserProfile?
  musicConnections MusicConnection[]
  playlists        Playlist[]
  posts            Post[]            @relation("AuthoredPosts")
  comments         Comment[]
  reactions        Reaction[]
  followers        Follow[]          @relation("Following")
  following        Follow[]          @relation("Followers")
  links            Link[]
  nowPlaying       NowPlaying?
  notifications    Notification[]    @relation("NotificationRecipient")
  actedNotifications Notification[]  @relation("NotificationActor")
  pollVotes        PollVote[]
  hostedSessions   ListeningSession[] @relation("SessionHost")
  sentMessages     DirectMessage[]   @relation("MessageSender")
  accounts         Account[]
  sessions         AuthSession[]

  conversationsAsUser1 Conversation[] @relation("ConversationUser1")
  conversationsAsUser2 Conversation[] @relation("ConversationUser2")
  forumThreads     ForumThread[] @relation("ForumThreads")
  forumReplies     ForumReply[]  @relation("ForumReplies")

  @@index([username])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Profile Customization ──────────────────────────────────────

model UserProfile {
  id                String      @id @default(cuid())
  userId            String      @unique
  profilePictureUrl String?
  bannerUrl         String?
  bannerVideoUrl    String?
  backgroundColor   String?     @default("#0a0a0a")
  backgroundImageUrl String?
  backgroundOpacity Float?      @default(1.0)
  primaryColor      String?     @default("#8b5cf6")
  secondaryColor    String?     @default("#6d28d9")
  accentColor       String?     @default("#a78bfa")
  fontFamily        String?     @default("Inter")
  fontWeight        String?     @default("400")
  headingFont       String?     @default("Space Grotesk")
  bioFontSize       String?     @default("base")
  textEffects       Json?       @default("{}")
  layoutStyle       LayoutStyle @default(CLASSIC)
  profileSongId     String?
  autoplayProfileSong Boolean   @default(false)
  customCSS         String?     @db.Text
  vibeBoard         Json?       @default("[]")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileSong MusicTrack? @relation(fields: [profileSongId], references: [id])
}

// ─── Music Services ─────────────────────────────────────────────

model MusicConnection {
  id               String            @id @default(cuid())
  userId           String
  provider         MusicProviderType
  accessToken      String            @db.Text
  refreshToken     String?           @db.Text
  providerUserId   String?
  providerUsername  String?
  expiresAt        DateTime?
  scopes           String?
  isActive         Boolean           @default(true)
  isPrimary        Boolean           @default(false)
  connectedAt      DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

model MusicTrack {
  id              String  @id @default(cuid())
  provider        MusicProviderType
  providerTrackId String
  title           String
  artist          String
  album           String?
  albumArtUrl     String?
  previewUrl      String?
  duration        Int?
  isrc            String?
  externalUrl     String?
  syncedLyricsData Json?
  createdAt       DateTime @default(now())

  posts           Post[]
  comments        Comment[]
  playlistTracks  PlaylistTrack[]
  pollOptions     PollOption[]
  nowPlayingUsers NowPlaying[]
  profileSongs    UserProfile[]
  sessionTracks   ListeningSession[]

  @@unique([provider, providerTrackId])
  @@index([isrc])
  @@index([title, artist])
}

model Playlist {
  id                 String            @id @default(cuid())
  userId             String
  provider           MusicProviderType
  providerPlaylistId String
  name               String
  description        String?           @db.Text
  coverImageUrl      String?
  trackCount         Int               @default(0)
  isPublic           Boolean           @default(true)
  isPinned           Boolean           @default(false)
  displayOrder       Int               @default(0)
  importedAt         DateTime          @default(now())
  lastSyncedAt       DateTime          @default(now())

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks PlaylistTrack[]
  posts  Post[]

  @@unique([userId, provider, providerPlaylistId])
  @@index([userId])
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  trackId    String
  position   Int
  addedAt    DateTime @default(now())

  playlist Playlist   @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    MusicTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
  @@index([playlistId])
}

// ─── Posts ───────────────────────────────────────────────────────

model Post {
  id                 String     @id @default(cuid())
  authorId           String
  type               PostType   @default(TEXT)
  content            String?    @db.Text
  mediaUrls          String[]
  videoUrl           String?
  thumbnailUrl       String?
  attachedTrackId    String?
  attachedPlaylistId String?
  pollId             String?    @unique
  lyricCardData      Json?
  visibility         Visibility @default(PUBLIC)
  repostOfId         String?
  scheduledFor       DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  editedAt           DateTime?

  author           User       @relation("AuthoredPosts", fields: [authorId], references: [id], onDelete: Cascade)
  attachedTrack    MusicTrack? @relation(fields: [attachedTrackId], references: [id])
  attachedPlaylist Playlist?  @relation(fields: [attachedPlaylistId], references: [id])
  poll             Poll?      @relation(fields: [pollId], references: [id])
  repostOf         Post?      @relation("Reposts", fields: [repostOfId], references: [id])
  reposts          Post[]     @relation("Reposts")
  comments         Comment[]
  reactions        Reaction[]

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@index([visibility, createdAt(sort: Desc)])
}

model Poll {
  id            String    @id @default(cuid())
  question      String
  allowMultiple Boolean   @default(false)
  expiresAt     DateTime
  createdAt     DateTime  @default(now())

  post    Post?
  options PollOption[]
}

model PollOption {
  id              String  @id @default(cuid())
  pollId          String
  text            String
  attachedTrackId String?

  poll          Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  attachedTrack MusicTrack? @relation(fields: [attachedTrackId], references: [id])
  votes         PollVote[]

  @@index([pollId])
}

model PollVote {
  id           String   @id @default(cuid())
  pollOptionId String
  userId       String
  votedAt      DateTime @default(now())

  option PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollOptionId, userId])
}

// ─── Comments ───────────────────────────────────────────────────

model Comment {
  id              String   @id @default(cuid())
  postId          String
  authorId        String
  parentId        String?
  content         String   @db.Text
  attachedTrackId String?
  createdAt       DateTime @default(now())
  editedAt        DateTime?

  post          Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  author        User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent        Comment?   @relation("CommentReplies", fields: [parentId], references: [id])
  replies       Comment[]  @relation("CommentReplies")
  attachedTrack MusicTrack? @relation(fields: [attachedTrackId], references: [id])
  reactions     Reaction[]

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

// ─── Reactions ──────────────────────────────────────────────────

model Reaction {
  id        String       @id @default(cuid())
  userId    String
  postId    String?
  commentId String?
  type      ReactionType
  createdAt DateTime     @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post    Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, type])
  @@unique([userId, commentId, type])
  @@index([postId])
  @@index([commentId])
}

// ─── Social ─────────────────────────────────────────────────────

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Followers", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Link {
  id           String  @id @default(cuid())
  userId       String
  title        String
  url          String
  iconType     String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)
  clickCount   Int     @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Now Playing ────────────────────────────────────────────────

model NowPlaying {
  id        String            @id @default(cuid())
  userId    String            @unique
  trackId   String
  startedAt DateTime          @default(now())
  provider  MusicProviderType
  isActive  Boolean           @default(true)

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  track MusicTrack @relation(fields: [trackId], references: [id])
}

// ─── Notifications ──────────────────────────────────────────────

model Notification {
  id            String           @id @default(cuid())
  userId        String
  actorId       String?
  type          NotificationType
  referenceId   String?
  referenceType String?
  read          Boolean          @default(false)
  createdAt     DateTime         @default(now())

  user  User  @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id])

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
}

// ─── Listening Sessions ─────────────────────────────────────────

model ListeningSession {
  id             String   @id @default(cuid())
  hostId         String
  name           String
  isActive       Boolean  @default(true)
  participantIds String[]
  currentTrackId String?
  createdAt      DateTime @default(now())

  host         User       @relation("SessionHost", fields: [hostId], references: [id], onDelete: Cascade)
  currentTrack MusicTrack? @relation(fields: [currentTrackId], references: [id])

  @@index([hostId])
  @@index([isActive])
}

// ─── Direct Messages ────────────────────────────────────────────

model Conversation {
  id        String   @id @default(cuid())
  user1Id   String
  user2Id   String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user1    User            @relation("ConversationUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2    User            @relation("ConversationUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages DirectMessage[]

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

model DirectMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String   @db.Text
  attachedTrackId String?
  read           Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([senderId])
}

// ─── Forum ─────────────────────────────────────────────────────

model ForumCategory {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  icon        String? // emoji or icon name
  color       String? @default("#8b5cf6")
  parentId    String?
  sortOrder   Int     @default(0)
  isLocked    Boolean @default(false)

  parent   ForumCategory?  @relation("SubCategories", fields: [parentId], references: [id])
  children ForumCategory[] @relation("SubCategories")
  threads  ForumThread[]

  @@index([parentId])
  @@index([slug])
}

model ForumThread {
  id          String   @id @default(cuid())
  categoryId  String
  authorId    String
  title       String
  content     String   @db.Text
  audioUrl    String?  // for indie music submissions
  audioTitle  String?
  isPinned    Boolean  @default(false)
  isLocked    Boolean  @default(false)
  viewCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastReplyAt DateTime @default(now())

  category ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author   User          @relation("ForumThreads", fields: [authorId], references: [id], onDelete: Cascade)
  replies  ForumReply[]

  @@index([categoryId, lastReplyAt(sort: Desc)])
  @@index([categoryId, isPinned])
  @@index([authorId])
}

model ForumReply {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  content   String   @db.Text
  audioUrl  String?
  parentId  String?
  createdAt DateTime @default(now())
  editedAt  DateTime?

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User        @relation("ForumReplies", fields: [authorId], references: [id], onDelete: Cascade)
  parent ForumReply? @relation("ReplyReplies", fields: [parentId], references: [id])
  replies ForumReply[] @relation("ReplyReplies")

  @@index([threadId, createdAt])
  @@index([authorId])
}
